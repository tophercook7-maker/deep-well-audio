# =============================================================================
# Deep Well Audio — environment template
# Copy to `.env.local` for local dev:  cp .env.example .env.local
# Then fill values and restart `npm run dev`.
#
# On Vercel: Project Settings → Environment Variables (same names).
# Never commit `.env.local` or real secrets.
# =============================================================================

# --- Public (exposed to the browser) ---

# Supabase project URL (Dashboard → Settings → API).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / public key (Dashboard → Settings → API).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site origin for auth email links, Stripe redirects, and checkout UI (no trailing slash).
# Local:   http://localhost:3000
# Production (Deep Well): https://deepwellaudio.com
# Preview: https://your-preview.vercel.app
# Must match entries you add in Supabase → Authentication → URL configuration.
NEXT_PUBLIC_SITE_URL=

# Stripe publishable key (safe for browser; enables upgrade UI hints).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Server-only (never use in client code; do not prefix with NEXT_PUBLIC_) ---

# Service role key — ingestion & admin DB access only (Dashboard → Settings → API).
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails allowed to open /admin/feedback (e.g. you@domain.com,ops@domain.com).
# FEEDBACK_ADMIN_EMAILS=

# Secret for POST /api/sync/all and /api/ingest/* (Bearer or ?secret=).
SYNC_API_SECRET=

# Never enable in production — local/testing only; sets plan via POST /api/account/upgrade-stub.
# ALLOW_STUB_PREMIUM_UPGRADE=1

# Stripe subscriptions (Checkout + webhooks). See README “Stripe”.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# --- Bible listen: premium TTS (server-only — never use NEXT_PUBLIC_ for keys) ---
# ElevenLabs (recommended): API key + at least one voice ID. Use ELEVENLABS_DEFAULT_VOICE_ID
# for all curated voices, or set ELEVENLABS_VOICE_WARM_MALE, etc., per voice.
# If ElevenLabs is not configured, OPENAI_API_KEY enables OpenAI `tts-1-hd` as fallback.
# ELEVENLABS_API_KEY=
# ELEVENLABS_DEFAULT_VOICE_ID=
# ELEVENLABS_VOICE_WARM_MALE=
# ELEVENLABS_VOICE_GENTLE_FEMALE=
# ELEVENLABS_VOICE_DEEP_VOICE=
# ELEVENLABS_VOICE_CALM_STUDY=
# ELEVENLABS_VOICE_STEADY_NARRATOR=
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# OPENAI_API_KEY=
# OPENAI_TTS_MODEL=tts-1-hd

# --- Optional (add later) ---

# Optional: secondary mailto link on /pricing#notify (e.g. hello@yourdomain.com).
# NEXT_PUBLIC_PREMIUM_WAITLIST_EMAIL=

# YouTube Data API v3 — **recommended** for curated channel ingestion (primary path); RSS used as fallback.
YOUTUBE_API_KEY=
#
# Bearer for cron routes (Vercel `vercel.json` schedules World Watch ingest + curated YouTube cache warm).
# CRON_SECRET=

# --- Optional post-launch: World Watch weekly email (Premium only; NOT required for launch) ---
# `/world-watch` and Premium gating work without any of this. Leave everything below unset until you use Resend.
#
# Step 1: Set to 1 only when you are ready to send (endpoint returns 403 otherwise).
# WORLD_WATCH_WEEKLY_DIGEST_ENABLED=1
#
# Step 2: Bearer secret for GET /api/cron/world-watch-weekly (manual cron, GitHub Actions, etc.—no vercel.json schedule in repo).
# CRON_SECRET=
#
# Step 3: Resend (https://resend.com)
# RESEND_API_KEY=
# RESEND_FROM_WORLD_WATCH=   # e.g. World Watch <digest@updates.yourdomain.com>
